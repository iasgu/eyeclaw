LLM=glm-5v-turbo
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_API_KEY=your-zhipu-api-key
LLM_GLM_THINKING=disabled

VLM=glm-5v-turbo
VLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
VLM_API_KEY=${LLM_API_KEY}
VLM_GLM_THINKING=disabled

EXECUTION_ROUTER_USE_LLM=false

BROWSER_USE_FAST_MODE=true
# Browser Use needs a tool-calling model. DeepSeek thinking/reasoner models reject tool_choice.
# EyeClaw keeps DeepSeek on native JSON-object compatibility mode by default to avoid tool_choice errors.
BROWSER_USE_LLM=glm-5v-turbo
BROWSER_USE_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
BROWSER_USE_LLM_API_KEY=${LLM_API_KEY}
BROWSER_USE_GLM_THINKING=disabled
BROWSER_USE_DEEPSEEK_NATIVE_TOOLS=false
# GLM-5V-Turbo is the official multimodal model name; keep thinking disabled for structured JSON/browser execution.
BROWSER_USE_MAX_STEPS=14
BROWSER_USE_MAX_ACTIONS_PER_STEP=8
BROWSER_USE_LLM_TIMEOUT=45
BROWSER_USE_STEP_TIMEOUT=60
BROWSER_USE_WAIT_BETWEEN_ACTIONS=0.03
BROWSER_USE_MAX_IFRAMES=5
BROWSER_USE_MAX_IFRAME_DEPTH=1
BROWSER_USE_SCREENSHOT_TIMEOUT=1.5

EDGE_USER_DATA_DIR=.browser/edge-profile
EDGE_CHANNEL=msedge
TARGET_SITE_URL=https://eia.51dzhp.com/#/
