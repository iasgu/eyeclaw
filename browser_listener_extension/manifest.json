{
  "manifest_version": 3,
  "name": "Eyeclaw Listener",
  "version": "0.1.0",
  "description": "Local browser listener for Eyeclaw. Captures navigation, tabs, clicks, inputs, and scrolls.",
  "permissions": ["activeTab", "offscreen", "storage", "tabCapture", "tabs", "webNavigation"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1/*", "http://localhost/*"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["offscreen.html", "offscreen.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Eyeclaw Listener"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ]
}
